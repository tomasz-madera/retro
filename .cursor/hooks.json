{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.js",
        "event": "sessionStart",
        "description": "Load previous session context from .cursor/sessions/"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/session-end.js",
        "event": "sessionEnd",
        "description": "Persist session state for cross-session continuity"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/before-shell-execution.js",
        "event": "beforeShellExecution",
        "description": "Block git --no-verify and core.hooksPath bypass"
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/before-read-file.js",
        "event": "beforeReadFile",
        "description": "Warn when reading sensitive files (.env, .key, .pem)"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/before-submit-prompt.js",
        "event": "beforeSubmitPrompt",
        "description": "Detect secrets in prompts"
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "node .cursor/hooks/before-tab-file-read.js",
        "event": "beforeTabFileRead",
        "description": "Block Tab from reading secrets"
      }
    ],
    "preCompact": [
      {
        "command": "node .cursor/hooks/pre-compact.js",
        "event": "preCompact",
        "description": "Mark compaction in session file before context summarization"
      }
    ]
  }
}
